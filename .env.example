# Supabase connection — copy this file to `.env.local` and fill in the values.
# Find both in your Supabase project: Settings → API.
#   - Project URL          → VITE_SUPABASE_URL
#   - anon / public key    → VITE_SUPABASE_ANON_KEY
# The anon key is safe to expose in the browser; row-level security protects data.
# Vite only exposes vars prefixed with VITE_ to the front-end.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
